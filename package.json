{
  "name": "multi-agent-research-system",
  "private": true,
  "version": "1.0.0",
  "description": "Elite Multi-Agent AI Scientific Research System",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite",
    "server:dev": "tsx watch engine/server.ts",
    "build": "vite build && tsc -p tsconfig.engine.json",
    "build:frontend": "vite build",
    "server:start": "node dist/engine/server.js",
    "start": "tsx engine/server.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "vue": "^3.2.25",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vercel/node": "^5.6.6",
    "@vitejs/plugin-vue": "^2.3.3",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^2.9.9"
  }
}
