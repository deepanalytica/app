# Multi-Agent Research System — Environment Variables

# ── REQUIRED ──────────────────────────────────────────
# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL ──────────────────────────────────────────
# Backend server port (default: 3001)
PORT=3001

# ── FRONTEND (Vite env vars must start with VITE_) ────
# Backend API URL (default: http://localhost:3001)
VITE_API_URL=http://localhost:3001

# Backend WebSocket URL (default: ws://localhost:3001)
VITE_WS_URL=ws://localhost:3001
